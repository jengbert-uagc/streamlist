VITE_TMDB_API_KEY=your_tmdb_api_key
VITE_TMDB_API_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
VITE_AUTH_API_URL=
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173
SESSION_COOKIE_NAME=streamlist_session
SESSION_TTL_MS=604800000
SESSION_SECURE_COOKIES=false
CSRF_COOKIE_NAME=streamlist_csrf
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional; defaults to {PUBLIC_BASE_URL}/api/auth/google/callback or request origin.
GOOGLE_OAUTH_REDIRECT_URI=
# Optional; defaults to "openid email profile"
GOOGLE_OAUTH_SCOPES=openid email profile
# Optional public origin used to build callback URL when GOOGLE_OAUTH_REDIRECT_URI is blank.
PUBLIC_BASE_URL=
OAUTH_STATE_TTL_MS=600000
